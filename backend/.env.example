# =============================================================================
# Enix Exteriors API — environment template
# Copy to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# --- Server ---
PORT=3001
NODE_ENV=production
LOG_LEVEL=info

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://enix_user:CHANGE_ME@localhost:5432/enix_prime_flow
DB_POOL_MAX=20

# --- Auth (JWT) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_BYTE_HEX_FOR_ACCESS_TOKEN
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_FOR_REFRESH
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- CORS allowlist (comma separated) ---
CORS_ORIGINS=https://enixexteriors.com,https://www.enixexteriors.com

# --- Cookies ---
COOKIE_DOMAIN=enixexteriors.com
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# --- File uploads (local fs in v1, S3 later) ---
UPLOAD_DIR=/var/www/enix-prime-flow/uploads
MAX_UPLOAD_BYTES=10485760

# --- Email (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=CHANGE_ME
EMAIL_FROM="Enix Exteriors <noreply@enixexteriors.com>"
LEAD_NOTIFY_EMAIL=leads@enixexteriors.com

# --- Public URLs ---
APP_BASE_URL=https://enixexteriors.com
API_BASE_URL=https://api.enixexteriors.com

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX_PUBLIC=5
RATE_LIMIT_MAX_AUTHED=100
