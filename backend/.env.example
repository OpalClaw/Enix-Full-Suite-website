# =============================================================================
# Enix Backend API — environment variables
# Copy to .env and fill in. NEVER commit .env to git.
# =============================================================================

# ---- Server ----
NODE_ENV=development            # development | test | production
PORT=3001
LOG_LEVEL=info                  # trace | debug | info | warn | error | fatal

# ---- Database ----
# PostgreSQL connection string. Production should use TLS (`sslmode=require`).
DATABASE_URL=postgres://enix_user:CHANGE_ME@localhost:5432/enix_prime_flow
DB_POOL_MAX=20

# ---- JWT secrets ----
# Both required. MUST be different from each other (server refuses to start
# if they are equal). Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_HEX_ACCESS_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_HEX_REFRESH_SECRET
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Cookie config ----
COOKIE_SECURE=true              # set to "false" only for local HTTP dev
COOKIE_SAMESITE=lax             # strict | lax | none
COOKIE_DOMAIN=                  # e.g. .enixexteriors.com (leave empty for default)

# ---- CORS ----
# Comma-separated allowlist. The server refuses to start in production
# if this is empty (no wildcard, no implicit-allow).
CORS_ORIGINS=https://enixexteriors.com,https://www.enixexteriors.com

# ---- Rate limits ----
# Lead intake (public POST /api/leads) — strict.
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX_PUBLIC=5

# ---- Account lockout ----
LOCKOUT_THRESHOLD=5             # consecutive failures before lock
LOCKOUT_WINDOW_MS=900000        # 15 min — window to count failures
LOCKOUT_DURATION_MS=900000      # 15 min — how long the account stays locked

# ---- Email (transactional) ----
# Optional — leave empty to disable email sending. Errors are logged but
# never propagated to the client.
EMAIL_PROVIDER=                 # resend | sendgrid | postmark | smtp
EMAIL_FROM=noreply@enixexteriors.com
EMAIL_REPLY_TO=office@enixexteriors.com
RESEND_API_KEY=
SENDGRID_API_KEY=
POSTMARK_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ---- Cloudflare Turnstile (optional anti-bot on public lead form) ----
TURNSTILE_SECRET=

# ---- Smart Documents ----
# Directory where generated PDFs are stored (tenant-isolated).
# Production: a private object store (S3) is recommended.
DOCUMENTS_DIR=/var/lib/enix/documents
