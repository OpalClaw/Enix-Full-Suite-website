# =============================================================================
# Enix Leads-API — environment variables
# Copy to .env (DO NOT commit). On Zo Space, set these in
# Settings → Advanced → Secrets.
# =============================================================================

# Path where leads.json is persisted on the host filesystem.
# On Zo Space, anywhere under /home/workspace is durable.
LEADS_FILE=/home/workspace/Documents/Enix/leads.json

# Comma-separated list of allowed Origin headers for POST /api/enix-lead.
# No wildcard. Every public origin you serve the form from must be listed.
ALLOWED_ORIGINS=https://enixexteriors.com,https://www.enixexteriors.com

# Opaque random secret for GET /api/enix-leads-export bearer auth.
# Generate: openssl rand -hex 32
# 64-char hex string recommended; never reuse across environments.
ENIX_LEADS_EXPORT_TOKEN=REPLACE_WITH_OPAQUE_RANDOM_64_CHAR_HEX

# Optional — override the rate limit (defaults: 5 leads / 600s window).
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=600000

# Optional — warn when leads.json exceeds this size (default 10000).
LEADS_SOFT_LIMIT=10000

# Optional — maximum JSON body size in bytes (default 65536 = 64KB).
# Reject larger payloads with 413 before parsing.
MAX_BODY_BYTES=65536
