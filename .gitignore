# =============================================================================
# Enix Exteriors Full Suite — .gitignore
# =============================================================================

# ---- Dependencies & build artifacts ----
**/node_modules/
**/dist/
**/build/
**/.vite/
**/.next/
**/.turbo/
**/coverage/
**/.nyc_output/

# ---- Environment & secrets ----
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test
**/.env
**/.env.local
**/.env.*.local
**/.env.production

# Certificates / keys / signed payloads
*.pem
*.key
*.crt
*.cer
*.der
*.p12
*.pfx
*.jks
*.keystore
secrets/
private/

# ---- Local lead data (production data lives in the DB / leads-api host) ----
leads.json
**/leads.json
backups/

# ---- Logs ----
*.log
**/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*

# ---- IDE / OS ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
.history/

# ---- Test outputs ----
coverage/
test-results/
playwright-report/
junit.xml

# ---- Packaging artifacts ----
*.tar.gz
*.tgz
*.sha256
*.zip
artifacts/

# ---- Drizzle ----
backend/drizzle/
backend/.drizzle/

# ---- Local databases ----
*.sqlite
*.sqlite3
*.db

# ---- Frontend-specific ----
frontend/.cache/
frontend/.parcel-cache/
frontend/stats.html

# ---- AI / scratch ----
.aider*
.claude/
.cursor/
